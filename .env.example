# Copy to .env before deploying the frontends to Cloudflare Pages.
# `.env` is gitignored.
#
# --- Cloudflare deploy token (Pages deploy via wrangler)
CLOUDFLARE_DEPLOY_WORKERS_TOKEN=""
# --- Cloudflare account id (necessary for deploys to work)
CLOUDFLARE_ACCOUNT_ID=""
# --- Cloudflare zone id (necessary for cache purge)
CLOUDFLARE_ZONE_ID=""
